# Docker Environment Configuration

# Option 1: Use Neon PostgreSQL (Remote)
# DATABASE_URL="postgresql://neondb_owner:npg_xxx@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Option 2: Use Local PostgreSQL (via docker-compose)
DATABASE_URL="postgresql://postgres:postgres@db:5432/neondb?sslmode=disable"

# Local database credentials (for docker-compose postgres service)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=neondb

# Server port
PORT=3000
